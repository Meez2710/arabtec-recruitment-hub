# ============================================================================
# Arabtec Recruitment Hub — environment template
# Copy to `.env` and fill in. NEVER commit a real .env or real secret values.
# Full reference: docs/ENVIRONMENT_VARIABLES.md
# ============================================================================

# --- Database -------------------------------------------------------------
# Local dev (default, zero-setup): SQLite. Start with `npm run start:sqlite`.
DATABASE_URL="file:./dev.db"
# Production: PostgreSQL. Example:
#   DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/arabtec?sslmode=require"
# Optional Postgres tuning:
# PG_ENGINE=              # set to "pglite" only for in-process Postgres verification
# PG_DATA=                # data dir when PG_ENGINE=pglite (persistence)
# PG_NO_SSL=              # "true" to disable TLS (localhost/self-hosted same box only)

# --- Auth / sessions ------------------------------------------------------
# REQUIRED in production. Use a long (32+ char) random string. The app refuses
# to start in production without it. Generate: `openssl rand -hex 32`.
JWT_SECRET="change-me-in-production-please-use-a-long-random-string"
JWT_EXPIRES_IN="2h"
JWT_REMEMBER_EXPIRES_IN="7d"
BCRYPT_ROUNDS=10
# Account lockout after this many consecutive failed logins:
LOGIN_LOCK_THRESHOLD=5
LOGIN_LOCK_MINUTES=15

# --- Server / networking --------------------------------------------------
PORT=4000
NODE_ENV=development
# Comma-separated allowed CORS origins (the browser app's public URL(s)).
# UPDATE THIS to the custom domain at go-live, e.g. https://ats.arabtec-hr.com
CORS_ORIGINS="http://localhost:5173,http://localhost:4000,http://127.0.0.1:4000"
# Number of proxy hops to trust for req.ip (prevents X-Forwarded-For spoofing).
# Production behind Render/Coolify/Nginx = 1. Local dev = leave unset (off).
TRUST_PROXY=1
# Global API rate limiter (per IP):
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_DISABLED=true   # tests only

# --- Security headers -----------------------------------------------------
# HSTS is sent only when NODE_ENV=production. Max-age in seconds (default 180d).
HSTS_MAX_AGE=15552000
# Roll out CSP safely by observing violations first (does not block):
# CSP_REPORT_ONLY=true
# SECURITY_HEADERS_DISABLED=true   # debugging escape hatch — NEVER in production

# --- Seed admin (used only by the first-run seed) -------------------------
# In production leave SEED_ADMIN_PASSWORD BLANK so a strong random one is
# generated and printed ONCE; the admin must rotate it at first login.
SEED_ADMIN_EMAIL="admin@arabtec.com"
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="System Administrator"
# SEED_DEMO_DATA=false   # true only in local/staging to seed demo users

# --- Email (SMTP) — leave USER/PASS blank to keep email OFF ---------------
# Gmail now:   SMTP_HOST=smtp.gmail.com,   SMTP_PORT=587
# M365 later:  SMTP_HOST=smtp.office365.com (IT must enable SMTP AUTH)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_FROM_NAME="Arabtec Careers"
# SMTP_TRANSPORT=json   # dry-run: build emails without sending (tests only)

# --- AI CV parsing — leave keys blank to use the heuristic parser ---------
# DeepSeek / SiliconFlow (used by the CV folder watcher):
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"
# Anthropic (used by the on-demand CV parser). Requires @anthropic-ai/sdk installed.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# --- Uploads / file storage ----------------------------------------------
# Persistent directory for uploaded files. On VPS/Coolify point this at a mounted
# volume. If unset, files are stored durably in the DB blob table (see docs).
UPLOAD_DIR=

# --- CV inbox folder watcher (feature.folder_watcher) ---------------------
CV_INBOX=
CV_WATCH_INTERVAL_MIN=60

# --- Monitoring / error tracking ------------------------------------------
# Set to enable Sentry error tracking in production (do NOT commit the value):
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
