# Copy this file to .env and adjust as needed.
# --- Database ---
# SQLite (default, zero-setup). To migrate to PostgreSQL later, change the
# provider in prisma/schema.prisma to "postgresql" and set DATABASE_URL accordingly.
DATABASE_URL="file:./dev.db"

# --- Auth ---
JWT_SECRET="change-me-in-production-please-use-a-long-random-string"
JWT_EXPIRES_IN="2h"
JWT_REMEMBER_EXPIRES_IN="7d"
BCRYPT_ROUNDS=10
# Account lockout (C1.3): lock an account after this many consecutive failed logins.
LOGIN_LOCK_THRESHOLD=5
LOGIN_LOCK_MINUTES=15

# --- Email sending (C2.2) ---
# Leave SMTP_USER / SMTP_PASS blank to keep email OFF (app runs fine; nothing is sent).
# TESTING with Gmail now:  SMTP_HOST=smtp.gmail.com, SMTP_USER=adly.moutaz@gmail.com,
#   SMTP_PASS=<a Google App Password>, MAIL_FROM=adly.moutaz@gmail.com
# LATER with Microsoft 365: SMTP_HOST=smtp.office365.com, SMTP_USER=career@arabtecegy.com,
#   SMTP_PASS=<mailbox app password>, MAIL_FROM=career@arabtecegy.com  (IT must enable SMTP AUTH)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_FROM_NAME="Arabtec Careers"
# SMTP_TRANSPORT=json   # dry-run: builds emails without sending (tests only)

# --- Server ---
PORT=4000
NODE_ENV=development
# Comma-separated allowed origins for CORS (frontend dev server / static host)
CORS_ORIGINS="http://localhost:5173,http://localhost:4000,http://127.0.0.1:4000"

# --- Seed admin (used only by prisma/seed.js on first run) ---
# SECURITY: do NOT ship a real password here. Leave SEED_ADMIN_PASSWORD unset to have
# a strong random one generated and printed ONCE on first run, or set your own strong
# value in your local .env (never commit it). Either way the admin must rotate it at
# first login. This example intentionally leaves it blank.
SEED_ADMIN_EMAIL="admin@arabtec.com"
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="System Administrator"
